{
  "name": "clean-starter",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "eslint --config eslint.config.mjs --no-config-lookup \"packages/**/*.{ts,tsx,js,jsx}\"",
    "typecheck": "tsc -b",
    "depcruise": "depcruise packages --config .dependency-cruiser.js --include-only '^packages'"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^10.1.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "ts-node": "^10.9.1",
    "turbo": "^1.12.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "dependencies": {
    "@prisma/client": "^7.6.0",
    "@trpc/server": "^11.16.0",
    "prisma": "^7.6.0",
    "zod": "^4.3.6"
  }
}